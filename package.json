{
    "type": "module",
    "lint-staged": {
        "*.ts": [
            "npx eslint --cache --fix",
            "npx prettier --write"
        ],
        "*.{ts,css,md,json}": [
            "npx prettier --write"
        ]
    },
    "scripts": {
        "prepare": "husky install",
        "lint": "eslint \"src/**/*.ts\" --fix",
        "prettier": "prettier --write src",
        "compile": "tsc && npm run copy",
        "clean": "rimraf dist/",
        "copy": "npx copyfiles -u 1 src/.env src/**/*.json dist/",
        "build": "npm run lint && npm run prettier && npm run clean && npm run compile",
        "start": "npx copyfiles -u 1 \"src/**/*.json\" dist/ && npx copyfiles -f config.json dist/ && node dist/src/index.js",
        "dev": "node --env-file=.env --import tsx --watch src/index.ts",
        "prod": "npm run build && npm run start",
        "deploy": "node --env-file=.env --import tsx src/index.ts --deploy"
    },
    "dependencies": {
        "@discord-player/extractor": "^7.1.0",
        "@discordjs/opus": "0.10.0",
        "@discordjs/rest": "^2.0.1",
        "@discordjs/voice": "^0.19.0",
        "@libsql/client": "^0.17.0",
        "@prisma/adapter-libsql": "^6.4.1",
        "@prisma/client": "^6.4.1",
        "discord-player": "^7.1.0",
        "discord.js": "^14.13.0",
        "dotenv": "^17.3.1",
        "ffmpeg-static": "^5.3.0",
        "libsodium-wrappers": "^0.8.2",
        "opusscript": "^0.1.1",
        "play-dl": "^1.9.7",
        "shoukaku": "^4.3.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tsconfig/node20": "^20.1.1",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "^8.56.1",
        "eslint": "^10.0.2",
        "eslint-config-prettier": "^9.0.0",
        "husky": "^8.0.3",
        "lint-staged": "^14.0.1",
        "prettier": "^3.0.2",
        "prisma": "^6.4.1",
        "rimraf": "^5.0.1",
        "tsx": "^4.21.0",
        "typescript": "^5.1.6",
        "typescript-eslint": "^8.56.1"
    }
}
